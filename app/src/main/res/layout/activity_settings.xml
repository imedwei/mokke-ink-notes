<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="28sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <!-- Sync -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sync"
            android:textSize="18sp"
            android:textColor="#666666"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/settingSyncFolder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Sync Folder"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/settingSyncFolderStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not configured"
            android:textSize="14sp"
            android:textColor="#888888"
            android:paddingStart="12dp"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <!-- Audio Transcription Engine -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lecture Transcription Engine"
            android:textSize="18sp"
            android:textColor="#666666"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <RadioGroup
            android:id="@+id/transcriptionEngineGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioSystem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="System (real-time, no audio saved)"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <RadioButton
                android:id="@+id/radioSherpa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sherpa (real-time + live partials, ~39 MB)"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <RadioButton
                android:id="@+id/radioVosk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vosk (real-time + saves audio, ~40 MB)"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <RadioButton
                android:id="@+id/radioWhisper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Whisper (highest accuracy, batch, ~75 MB)"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Help -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Help"
            android:textSize="18sp"
            android:textColor="#666666"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/settingTutorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Tutorial"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Debug -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Debug"
            android:textSize="18sp"
            android:textColor="#666666"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/settingDebugReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset All Data"
            android:textSize="20sp"
            android:textColor="#D32F2F"
            android:padding="12dp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Deletes all documents and resets all preferences."
            android:textSize="14sp"
            android:textColor="#888888"
            android:paddingStart="12dp"
            android:paddingBottom="8dp" />

    </LinearLayout>
</ScrollView>
