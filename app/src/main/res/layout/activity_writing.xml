<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Temporary undo/redo buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Undo"
            android:textSize="14sp"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnRedo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Redo"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Recognized text area — 25% of space, bottom-aligned -->
    <com.writer.view.RecognizedTextView
        android:id="@+id/recognizedTextView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white" />

    <!-- Divider between text and canvas -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#AAAAAA" />

    <!-- Ink canvas — 75% of space -->
    <com.writer.view.HandwritingCanvasView
        android:id="@+id/inkCanvas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3" />

</LinearLayout>
