<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Columns container: horizontal split for landscape Cornell Notes -->
    <LinearLayout
        android:id="@+id/columnsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/white">

        <!-- Main column: full-screen canvas (always visible) -->
        <FrameLayout
            android:id="@+id/mainColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/white">

            <com.writer.view.HandwritingCanvasView
                android:id="@+id/inkCanvas"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <!-- Column divider (landscape only) -->
        <View
            android:id="@+id/columnDivider"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#AAAAAA"
            android:visibility="gone" />

        <!-- Cue column: full-screen canvas (landscape only) -->
        <FrameLayout
            android:id="@+id/cueColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/white"
            android:visibility="gone">

            <com.writer.view.HandwritingCanvasView
                android:id="@+id/cueInkCanvas"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

    </LinearLayout>

    <!-- Cue indicator strip (portrait: right edge, shows dots where cues exist) -->
    <com.writer.view.CueIndicatorStrip
        android:id="@+id/cueIndicatorStrip"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:visibility="gone" />

    <!-- Context rail (portrait cue view: left edge, main content indicator + peek) -->
    <com.writer.view.CueIndicatorStrip
        android:id="@+id/contextRail"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:visibility="gone" />


    <!-- Floating gutter overlay: menu + undo + redo (top-right, independent of views) -->
    <LinearLayout
        android:id="@+id/gutterOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:elevation="1dp">

        <ImageView
            android:id="@+id/menuButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_mokke"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu" />

        <ImageView
            android:id="@+id/undoButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_undo"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Undo"
            />

        <ImageView
            android:id="@+id/redoButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_redo"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Redo"
            />

        <ImageView
            android:id="@+id/spaceInsertButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_unfold_more"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Insert or remove space"
            />

        <ImageView
            android:id="@+id/viewToggleButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_cue"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Switch to cues"
            />

        <ImageView
            android:id="@+id/rotateButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_screen_rotation"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Rotate screen"
            android:visibility="gone"
            />

    </LinearLayout>

    <!-- Tutorial overlay: dimmed background + cutout + tooltip (covers entire screen) -->
    <com.writer.view.TutorialOverlay
        android:id="@+id/tutorialOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>
