<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Columns container: horizontal split for landscape Cornell Notes -->
    <LinearLayout
        android:id="@+id/columnsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@color/white">

        <!-- Transcript column: full-height canvas (Phase 3c — hidden until
             the transcript display mode UI arrives in Phase 3d). -->
        <com.writer.view.HandwritingCanvasView
            android:id="@+id/transcriptInkCanvas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:visibility="gone" />

        <!-- Transcript divider (side-by-side layout only) -->
        <View
            android:id="@+id/transcriptColumnDivider"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#AAAAAA"
            android:visibility="gone" />

        <!-- Main column: full-height canvas (always visible) -->
        <com.writer.view.HandwritingCanvasView
            android:id="@+id/inkCanvas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Column divider (landscape only) -->
        <View
            android:id="@+id/columnDivider"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#AAAAAA"
            android:visibility="gone" />

        <!-- Cue column: full-height canvas (landscape only) -->
        <com.writer.view.HandwritingCanvasView
            android:id="@+id/cueInkCanvas"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Cue indicator strip (portrait: right edge, shows dots where cues exist) -->
    <com.writer.view.CueIndicatorStrip
        android:id="@+id/cueIndicatorStrip"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:visibility="gone" />

    <!-- Context rail (portrait cue view: left edge, main content indicator + peek) -->
    <com.writer.view.CueIndicatorStrip
        android:id="@+id/contextRail"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:visibility="gone" />

    <!-- Transcript indicator strip (small portrait: left edge in notes/cue view,
         shows dots where transcript text blocks exist; long-press to peek) -->
    <com.writer.view.CueIndicatorStrip
        android:id="@+id/transcriptIndicatorStrip"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:visibility="gone" />

    <!-- Main indicator strip (right edge, shown only in transcript view): lets
         the user peek main content which is spatially to the right of transcript. -->
    <com.writer.view.CueIndicatorStrip
        android:id="@+id/mainIndicatorStripRight"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:visibility="gone" />


    <!-- Floating gutter overlay: menu + undo + redo (top-right, independent of views) -->
    <LinearLayout
        android:id="@+id/gutterOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:elevation="1dp">

        <ImageView
            android:id="@+id/menuButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_mokke"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu" />

        <ImageView
            android:id="@+id/undoButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_undo"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Undo"
            />

        <ImageView
            android:id="@+id/redoButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_redo"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Redo"
            />

        <ImageView
            android:id="@+id/spaceInsertButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_unfold_more"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Insert or remove space"
            />

        <ImageView
            android:id="@+id/micButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_mic"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voice memo"
            />

        <ImageView
            android:id="@+id/viewToggleButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_cue"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Switch to cues"
            />

        <ImageView
            android:id="@+id/transcriptButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_transcript"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle transcript drawer"
            android:visibility="gone"
            />

        <ImageView
            android:id="@+id/rotateButton"
            android:layout_marginTop="16dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/ic_screen_rotation"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Rotate screen"
            android:visibility="gone"
            />

    </LinearLayout>

    <!-- Recording overlay bar (bottom, shown during recording) -->
    <com.writer.view.RecordingOverlayView
        android:id="@+id/recordingOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:elevation="2dp"
        android:visibility="gone" />

    <!-- Playback overlay bar (bottom, shown during playback) -->
    <com.writer.view.PlaybackOverlayView
        android:id="@+id/playbackOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:elevation="2dp"
        android:visibility="gone" />

    <!-- Version history overlay (bottom panel, shown in history mode) -->
    <com.writer.view.VersionHistoryOverlayView
        android:id="@+id/historyOverlay"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_gravity="bottom"
        android:elevation="0dp"
        android:visibility="gone" />

    <!-- Tutorial overlay: dimmed background + cutout + tooltip (covers entire screen) -->
    <com.writer.view.TutorialOverlay
        android:id="@+id/tutorialOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>
