<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <permission
        android:name="${applicationId}.permission.DEBUG"
        android:protectionLevel="signature" />

    <queries>
        <package android:name="com.onyx.android.ksync" />
    </queries>

    <application
        android:name=".WriterApplication"
        android:allowBackup="true"
        android:hasFragileUserData="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Writer">

        <activity
            android:name=".ui.documents.DocumentListActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.writing.WritingActivity"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="stateHidden" />

        <activity
            android:name=".ui.writing.SaveAsActivity"
            android:theme="@style/Theme.Writer.FullscreenDialog"
            android:configChanges="orientation|screenSize|screenLayout"
            android:windowSoftInputMode="stateHidden" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <service
            android:name=".audio.AudioRecordingService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <provider
            android:name=".ui.writing.DebugBugReportProvider"
            android:authorities="${applicationId}.debug"
            android:exported="true"
            android:permission="${applicationId}.permission.DEBUG" />
    </application>

</manifest>
